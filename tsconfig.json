{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*"]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts", "app/**/*", "types/**/*.ts"],
  "exclude": ["node_modules", "App.tsx", "__tests__/**", "backend/**"]
}
